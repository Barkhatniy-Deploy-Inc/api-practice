# --- СЕКРЕТНЫЕ КЛЮЧИ (НЕ КОММИТИТЬ В РЕПОЗИТОРИЙ!) ---

# Мастер-ключ для управления API (минимум 32 символа)
# Используется для генерации студенческих ключей: POST /api/v1/auth/keys
X_API_KEY=ваша_супер_секретная_строка_длиной_32_символа_и_более

# Соль для хеширования API-ключей студентов
# Смена этой переменной сделает все выданные ранее ключи недействительными!
AUTH_SALT=уникальная_строка_соли_для_защиты_хешей

# --- НАСТРОЙКИ СИСТЕМЫ ---

# URL базы данных (SQLite по умолчанию)
# Для PostgreSQL используйте: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:////app/data/dtp.db

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Режим отладки (true/false)
DEBUG_MODE=false
